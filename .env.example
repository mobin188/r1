# ==================== REQUIRED ====================

# Flask Environment
FLASK_ENV=development# Change to 'production' on VPS

# RealWorld API Backend
API_BASE=https://api.realworld.io/api

# Security - Must be changed in production
SECRET_KEY=your-super-secret-key-here-change-in-production

# Session Cookie Settings
# SESSION_COOKIE_SECURE - Production:True | Development (local HTTP):False
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ==================== OPTIONAL ====================

# Logging
LOG_LEVEL=INFO

# Failover Backend (for future use)
# FALLBACK_API=https://api.realworld.io/api

# Frontend CORS (if needed later)
# FRONTEND_URL=http://localhost:3000

# =============================================
# PRODUCTION SETUP NOTES:
# 1. On VPS: Copy this file to `.env`
# 2. Update SECRET_KEY with a strong random value
# 3. Never commit the real `.env` file to git
# 4. Secure permissions: chmod 600 .env
# 5. The automated deployment will use this file
# =============================================
