# ==================== REQUIRED ====================

# Flask Configuration
FLASK_ENV=development# Use 'production' on VPS

# RealWorld API Settings
API_BASE=https://api.realworld.io/api

# Security
SECRET_KEY=your-super-secret-key-here-change-in-production

# ==================== OPTIONAL ====================

# Backend Failover (if you implement fallback logic later)
# FALLBACK_API_BASE=https://api.realworld.io/api

# Logging Level
LOG_LEVEL=INFO

# CORS (if needed in the future)
# FRONTEND_URL=http://localhost:3000

# =============================================
# PRODUCTION NOTES:
# 1. On VPS: Copy this file to .env and update values
# 2. Use strong SECRET_KEY in production
# 3. Never commit real .env to git
# 4. Set proper permissions: chmod 600 .env
# =============================================
