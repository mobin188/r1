# ==================== REQUIRED ====================

# Flask Environment
FLASK_ENV=development# Change to 'production' on VPS

# RealWorld API Backend (empty FALLBACK_API = disabled)
API_BASE=https://api.realworld.io/api
FALLBACK_API=


# Security - Must be changed in production
SECRET_KEY=your-super-secret-key-here-change-in-production

# Session Cookie Settings
# SESSION_COOKIE_SECURE - Production:True | Development (local HTTP):False
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Request timeouts (seconds): connect and read phases
REQUEST_TIMEOUT_CONNECT=3
REQUEST_TIMEOUT_READ=25

# Circuit breaker thresholds
FAIL_THRESHOLD=3
COOLDOWN_SEC=10

# ==================== OPTIONAL ====================

# Logging
LOG_LEVEL=INFO
